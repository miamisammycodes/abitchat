parameters:
	ignoreErrors:
		-
			message: '#^Method App\\Models\\Tenant\:\:extendPlan\(\) invoked with 2 parameters, 1 required\.$#'
			identifier: arguments.count
			count: 1
			path: app/Http/Controllers/Admin/ClientController.php

		-
			message: '#^Unable to resolve the template type TKey in call to function collect$#'
			identifier: argument.templateType
			count: 1
			path: app/Http/Controllers/Client/WidgetController.php

		-
			message: '#^Unable to resolve the template type TValue in call to function collect$#'
			identifier: argument.templateType
			count: 1
			path: app/Http/Controllers/Client/WidgetController.php

		-
			message: '#^Offset ''limit'' on array\{used\: int, limit\: int\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Http/Middleware/HandleInertiaRequests.php

		-
			message: '#^Offset ''used'' on array\{used\: int, limit\: int\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Http/Middleware/HandleInertiaRequests.php

		-
			message: '#^Class App\\Models\\Conversation uses generic trait Illuminate\\Database\\Eloquent\\Factories\\HasFactory but does not specify its types\: TFactory$#'
			identifier: missingType.generics
			count: 1
			path: app/Models/Conversation.php

		-
			message: '#^Class App\\Models\\Message uses generic trait Illuminate\\Database\\Eloquent\\Factories\\HasFactory but does not specify its types\: TFactory$#'
			identifier: missingType.generics
			count: 1
			path: app/Models/Message.php

		-
			message: '#^Class App\\Models\\Tenant uses generic trait Illuminate\\Database\\Eloquent\\Factories\\HasFactory but does not specify its types\: TFactory$#'
			identifier: missingType.generics
			count: 1
			path: app/Models/Tenant.php

		-
			message: '#^Strict comparison using \!\=\= between string and null will always evaluate to true\.$#'
			identifier: notIdentical.alwaysTrue
			count: 1
			path: app/Services/LLM/ChatService.php

		-
			message: '#^Parameter \#1 \$relation of method App\\Services\\Usage\\UsageTracker\:\:countByPeriod\(\) expects Illuminate\\Database\\Eloquent\\Relations\\HasMany\<Illuminate\\Database\\Eloquent\\Model, App\\Models\\Tenant\>, Illuminate\\Database\\Eloquent\\Relations\\HasMany\<App\\Models\\Conversation, App\\Models\\Tenant\> given\.$#'
			identifier: argument.type
			count: 1
			path: app/Services/Usage/UsageTracker.php

		-
			message: '#^Parameter \#1 \$relation of method App\\Services\\Usage\\UsageTracker\:\:countByPeriod\(\) expects Illuminate\\Database\\Eloquent\\Relations\\HasMany\<Illuminate\\Database\\Eloquent\\Model, App\\Models\\Tenant\>, Illuminate\\Database\\Eloquent\\Relations\\HasMany\<App\\Models\\Lead, App\\Models\\Tenant\> given\.$#'
			identifier: argument.type
			count: 1
			path: app/Services/Usage/UsageTracker.php
