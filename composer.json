{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "abitchat/abitchat",
    "type": "project",
    "description": "AI-Powered WordPress Chatbot SaaS with RAG and Lead Capture",
    "keywords": ["chatbot", "ai", "wordpress", "saas", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "barryvdh/laravel-dompdf": "*",
        "firebase/php-jwt": "^7.0",
        "inertiajs/inertia-laravel": "*",
        "laravel/cashier": "*",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "prism-php/prism": "*",
        "resend/resend-laravel": "^1.4",
        "smalot/pdfparser": "*",
        "spatie/browsershot": "^5.4",
        "spatie/laravel-multitenancy": "*",
        "tightenco/ziggy": "*"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.0",
        "fakerphp/faker": "*",
        "larastan/larastan": "*",
        "laravel/boost": "^2.4",
        "laravel/pail": "*",
        "laravel/pint": "*",
        "laravel/sail": "*",
        "mockery/mockery": "*",
        "nunomaduro/collision": "*",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "pnpm install",
            "pnpm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "pnpm exec concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#86efac\" \"php artisan serve\" \"php artisan queue:listen --queue=crawls,default --tries=1\" \"php artisan pail --timeout=0\" \"pnpm run dev\" \"node resources/node/egress-proxy.mjs 8118\" --names=server,queue,logs,vite,proxy --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
