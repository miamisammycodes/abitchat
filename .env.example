APP_NAME=AbitChat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (Postgres + pgvector)
# Production: enable the vector extension once: CREATE EXTENSION IF NOT EXISTS vector;
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=chatbot
DB_USERNAME=postgres
DB_PASSWORD=

# Session & Cache (Redis recommended for production)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# LLM Configuration (Prism)
# Development: Ollama (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Production: Groq (cloud)
GROQ_API_KEY=

# Default LLM provider (ollama or groq)
LLM_PROVIDER=ollama

# Stripe (Billing)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Mail
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@abit.bt"
MAIL_FROM_NAME="AbitChat"
ADMIN_INQUIRY_EMAIL="support@abit.bt"

# Production: set MAIL_MAILER=resend and add RESEND_API_KEY
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# DK Bank Payment Gateway — see docs/superpowers/specs/2026-05-15-dk-bank-qr-design.md
DK_BANK_ENABLED=false
DK_BANK_BASE_URL=https://internal-gateway.sit.digitalkidu.bt:8082/api/dkpg
DK_BANK_API_KEY=
DK_BANK_USERNAME=
DK_BANK_PASSWORD=
DK_BANK_CLIENT_ID=
DK_BANK_CLIENT_SECRET=
DK_BANK_SOURCE_APP=
DK_BANK_BENEFICIARY_ACCOUNT=
DK_BANK_MCC_CODE=5817
DK_BANK_HTTP_TIMEOUT=30

# Widget session tokens — see docs/superpowers/specs/2026-05-18-widget-session-tokens-design.md
WIDGET_SESSION_DUAL_ACCEPT=true
WIDGET_SESSION_TTL=1800
WIDGET_IP_INIT_PER_MIN=10
WIDGET_IP_MESSAGE_PER_MIN=30
WIDGET_IP_DAILY_CAP=5000

# Headless rendering (Browsershot / Puppeteer) — see docs/superpowers/specs/2026-05-30-phase2-headless-render-fallback-design.md
CRAWLER_JS_RENDERING=false
# CRAWLER_RENDER_TIMEOUT=45
# CRAWLER_RENDER_DELAY=3000
# BROWSERSHOT_NODE_BINARY=
# BROWSERSHOT_NPM_BINARY=
# BROWSERSHOT_CHROME_PATH=
